{
  "name": "biblioteca-api",
  "version": "1.0.0",
  "description": "REST API for library room and material reservations",
  "main": "src/index.worker.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev:worker": "wrangler dev --local",
    "build": "tsc",
    "build:worker": "tsc && wrangler deploy --dry-run",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "migrate:local": "wrangler d1 execute biblioteca --local --file=migrations/001_init_schema.sql",
    "migrate:d1:staging": "wrangler d1 execute biblioteca-staging < migrations/001_init_schema.sql --env staging",
    "migrate:d1:prod": "wrangler d1 execute biblioteca < migrations/001_init_schema.sql --env production",
    "lint": "eslint src --ext .ts,.tsx,.test.ts,.test.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx,.test.ts,.test.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "library",
    "reservations",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "qrcode": "^1.5.4",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "itty-router": "^5.0.23",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "nock": "^14.0.13",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "wrangler": "^4.85.0"
  }
}
